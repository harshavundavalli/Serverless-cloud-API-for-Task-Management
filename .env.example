# Copy this to .env for local development (never commit .env)

# AWS / DynamoDB Local
IS_OFFLINE=true
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Tables (serverless-offline auto-creates these names)
TASKS_TABLE=task-management-api-tasks-dev
USERS_TABLE=task-management-api-users-dev

# JWT — change this in production!
JWT_SECRET=super-secret-local-dev-key-change-me

# Stage
STAGE=dev
